# ==========================================
# Terraform State & Local Configurations
# ==========================================
# Local .terraform directories (contains provider plugins and modules)
.terraform/

# Hide local CLI history logs
.terraform.lock.hcl

# Main state files and state backups
*.tfstate
*.tfstate.*

# Crash logs generated by Terraform
crash.log
crash.*.log

# ==========================================
# Variables and Secrets (CRITICAL)
# ==========================================
# Ignore all local variable files containing passwords, keys, or secret tokens
*.tfvars
*.tfvars.json

# Ignore local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ==========================================
# Security Keys & Certificates
# ==========================================
# Prevent your private SSH access keys from ever being uploaded to GitHub
*.pem
*.key
*.pub

# ==========================================
# System & Editor Files
# ==========================================
# MacOS system files
.DS_Store

# IDE / Text Editor directories
.idea/
.vscode/
*.swp
*.swo
